PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=healthfinder

# Optional. Leave unset (or remove) for browser-only sign-in — works on static hosts like InfinityFree.
# Set to http://localhost:3001 when running `npm run server` with Postgres (or your deployed API URL).
# VITE_API_BASE_URL=http://localhost:3001
